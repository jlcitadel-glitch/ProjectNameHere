# EditorConfig for ProjectNameHere
# https://editorconfig.org
root = true

# Default settings
[*]
indent_style = space
indent_size = 4
end_of_line = crlf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

# C# files
[*.cs]
indent_size = 4

# --- Naming Conventions (match STANDARDS.md) ---

# PascalCase for classes, structs, enums, interfaces, methods, properties, events
dotnet_naming_rule.types_should_be_pascal_case.symbols = types
dotnet_naming_rule.types_should_be_pascal_case.style = pascal_case_style
dotnet_naming_rule.types_should_be_pascal_case.severity = warning

dotnet_naming_symbols.types.applicable_kinds = class, struct, enum, interface, delegate
dotnet_naming_symbols.types.applicable_accessibilities = *

dotnet_naming_rule.methods_should_be_pascal_case.symbols = methods
dotnet_naming_rule.methods_should_be_pascal_case.style = pascal_case_style
dotnet_naming_rule.methods_should_be_pascal_case.severity = warning

dotnet_naming_symbols.methods.applicable_kinds = method, property, event
dotnet_naming_symbols.methods.applicable_accessibilities = *

dotnet_naming_style.pascal_case_style.capitalization = pascal_case

# camelCase for private/internal fields (no prefix — STANDARDS.md says no prefix)
dotnet_naming_rule.private_fields_should_be_camel_case.symbols = private_fields
dotnet_naming_rule.private_fields_should_be_camel_case.style = camel_case_style
dotnet_naming_rule.private_fields_should_be_camel_case.severity = warning

dotnet_naming_symbols.private_fields.applicable_kinds = field
dotnet_naming_symbols.private_fields.applicable_accessibilities = private, internal

dotnet_naming_style.camel_case_style.capitalization = camel_case

# camelCase for parameters and locals
dotnet_naming_rule.locals_should_be_camel_case.symbols = locals
dotnet_naming_rule.locals_should_be_camel_case.style = camel_case_style
dotnet_naming_rule.locals_should_be_camel_case.severity = warning

dotnet_naming_symbols.locals.applicable_kinds = parameter, local

# UPPER_CASE for constants
dotnet_naming_rule.constants_should_be_upper_case.symbols = constants
dotnet_naming_rule.constants_should_be_upper_case.style = upper_case_style
dotnet_naming_rule.constants_should_be_upper_case.severity = suggestion

dotnet_naming_symbols.constants.applicable_kinds = field
dotnet_naming_symbols.constants.required_modifiers = const

dotnet_naming_style.upper_case_style.capitalization = all_upper
dotnet_naming_style.upper_case_style.word_separator = _

# Interfaces should start with I
dotnet_naming_rule.interfaces_should_start_with_i.symbols = interfaces
dotnet_naming_rule.interfaces_should_start_with_i.style = interface_style
dotnet_naming_rule.interfaces_should_start_with_i.severity = warning

dotnet_naming_symbols.interfaces.applicable_kinds = interface

dotnet_naming_style.interface_style.required_prefix = I
dotnet_naming_style.interface_style.capitalization = pascal_case

# --- Code Style ---

# Use explicit types (var is fine for obvious types)
csharp_style_var_for_built_in_types = false:suggestion
csharp_style_var_when_type_is_apparent = true:silent
csharp_style_var_elsewhere = false:suggestion

# Prefer explicit accessibility modifiers (STANDARDS.md: "explicit private keyword")
dotnet_style_require_accessibility_modifiers = always:warning

# Prefer braces
csharp_prefer_braces = true:suggestion

# Expression-bodied members
csharp_style_expression_bodied_methods = when_on_single_line:suggestion
csharp_style_expression_bodied_properties = true:suggestion
csharp_style_expression_bodied_constructors = false:suggestion

# Null checking
csharp_style_conditional_delegate_call = true:warning
dotnet_style_null_propagation = true:suggestion
dotnet_style_coalesce_expression = true:suggestion

# Pattern matching
csharp_style_pattern_matching_over_is_with_cast_check = true:suggestion
csharp_style_pattern_matching_over_as_with_null_check = true:suggestion

# --- Formatting ---

# Newline preferences
csharp_new_line_before_open_brace = all
csharp_new_line_before_else = true
csharp_new_line_before_catch = true
csharp_new_line_before_finally = true

# Indentation
csharp_indent_case_contents = true
csharp_indent_switch_labels = true

# Spacing
csharp_space_after_cast = false
csharp_space_after_keywords_in_control_flow_statements = true
csharp_space_between_method_call_parameter_list_parentheses = false
csharp_space_between_method_declaration_parameter_list_parentheses = false

# Using directives
dotnet_sort_system_directives_first = true

# --- Analyzer Severity ---

# Suppress Unity-specific false positives
# CS0649: Field is never assigned (Unity assigns via SerializeField)
dotnet_diagnostic.CS0649.severity = none

# IDE0051: Remove unused private members (Unity message methods like Awake/Start)
dotnet_diagnostic.IDE0051.severity = none

# IDE0044: Make field readonly (Unity serialized fields can't be readonly)
dotnet_diagnostic.IDE0044.severity = none

# JSON files
[*.json]
indent_size = 2

# YAML files
[*.{yml,yaml}]
indent_size = 2

# Meta files (Unity)
[*.meta]
indent_size = 2
trim_trailing_whitespace = false

# Python CI scripts
[*.py]
indent_size = 4

# Markdown
[*.md]
trim_trailing_whitespace = false
